# Copy to .env — never commit .env (see .gitignore)

# Backend API (leave empty in dev to use Vite proxy to /api)
VITE_API_BASE_URL=

# Google Gemini — from https://aistudio.google.com/apikey (NOT a Cursor key)
VITE_GEMINI_API_KEY=
# Set to false to skip browser Gemini calls and use offline coach only
VITE_GEMINI_ENABLED=true
# Optional model override (defaults to gemini-2.5-flash)
# VITE_GEMINI_MODEL=gemini-2.5-flash

# Optional site gate (weak client-only barrier — not server authentication)
VITE_SITE_PASSWORD=
