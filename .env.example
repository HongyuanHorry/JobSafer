# Copy to .env - never commit .env (see .gitignore)

# Backend API (leave empty in dev to use Vite proxy to /api)
VITE_API_BASE_URL=

# Frontend toggle only. Set to false to skip live coach calls and use offline coach only
VITE_GEMINI_ENABLED=true

# In production set this when frontend and backend are hosted on different origins,
# e.g. VITE_API_BASE_URL=https://your-backend.example.com
# Keep empty in local dev if using Vite proxy.

# Backend Gemini (server-side only, never expose to browser)
GEMINI_API_KEY=
# Optional backend toggle
GEMINI_ENABLED=true
# Optional backend model override
# GEMINI_MODEL=gemini-2.5-flash-lite
